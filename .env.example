# Copy this file to .env.local for local development.
# .env.local is ignored by Git and can contain real credentials.

# Local database
APP_DB_PATH=data/app.sqlite

# Product archive sync queue
PRODUCT_ARCHIVE_SYNC_INTERVAL_MS=1500

# MDM production OpenAPI
MDM_BASE_URL=https://mdm.semirapp.com
MDM_APP_ID=
MDM_APP_KEY=

# DeepDraw OpenAPI
DEEPDRAW_BASE_URL=http://open.deepdraw.cn
DEEPDRAW_TENANT_NAME=电商巴拉巴拉
DEEPDRAW_APP_KEY=
DEEPDRAW_APP_SECRET=
DEEPDRAW_DOP_KEY=
DEEPDRAW_MERCHANT_ID=
# Optional JSON object keyed by DeepDraw tenant name.
DEEPDRAW_TENANT_CREDENTIALS_JSON=
DEEPDRAW_TIMEOUT_MS=30000

# Optional fallback: read DeepDraw credentials from a local document.
# DEEPDRAW_CREDENTIAL_DOC=docs/reference/integration-handoffs/private/MDM&深绘 (1).docx

# SHEIN OpenAPI
SHEIN_BASE_URL=https://openapi.sheincorp.cn
SHEIN_LANGUAGE=zh-cn
SHEIN_OPEN_KEY_ID=
SHEIN_SECRET_KEY=
