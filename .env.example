# Copy this file to .env.local for local development.
# .env.local is ignored by Git and can contain real credentials.

# Database
# Listingify now uses PostgreSQL for the web API and operational scripts.
DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://listingify:listingify@localhost:5432/listingify
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=3000
DATABASE_IDLE_TIMEOUT_MS=30000

# Web security
# Use a comma-separated allowlist for the Vite dev origins or production web origin.
LISTINGIFY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Required to auto-seed the first admin on startup. Prefer scripts/create_admin_user.mjs for local setup.
LISTINGIFY_ADMIN_USERNAME=admin
LISTINGIFY_ADMIN_PASSWORD=
LISTINGIFY_ADMIN_DISPLAY_NAME=系统管理员
# Used to encrypt stored platform secrets such as SHEIN secretKey. Keep stable once credentials are saved.
LISTINGIFY_CREDENTIAL_SECRET=
LISTINGIFY_LOGIN_MAX_FAILURES=5
LISTINGIFY_LOGIN_LOCK_MINUTES=15

# Product archive sync queue
PRODUCT_ARCHIVE_SYNC_INTERVAL_MS=1500

# MDM production OpenAPI
MDM_BASE_URL=https://mdm.semirapp.com
MDM_APP_ID=
MDM_APP_KEY=

# DeepDraw OpenAPI
DEEPDRAW_BASE_URL=http://open.deepdraw.cn
DEEPDRAW_TENANT_NAME=电商巴拉巴拉
DEEPDRAW_APP_KEY=
DEEPDRAW_APP_SECRET=
DEEPDRAW_DOP_KEY=
DEEPDRAW_MERCHANT_ID=
# Optional JSON object keyed by DeepDraw tenant name.
DEEPDRAW_TENANT_CREDENTIALS_JSON=
DEEPDRAW_TIMEOUT_MS=30000

# Optional fallback: read DeepDraw credentials from a local document.
# DEEPDRAW_CREDENTIAL_DOC=docs/reference/integration-handoffs/private/MDM&深绘 (1).docx

# SHEIN OpenAPI
SHEIN_BASE_URL=https://openapi.sheincorp.cn
SHEIN_LANGUAGE=zh-cn
SHEIN_OPEN_KEY_ID=
SHEIN_SECRET_KEY=

# AI category matching provider (OpenAI-compatible)
AI_BASE_URL=https://api.1xm.ai/v1
AI_MODEL=gemini-3-flash-preview
AI_API_KEY=
AI_TIMEOUT_MS=120000
